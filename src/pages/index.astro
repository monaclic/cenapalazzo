// Palazzo se fera ensuite ligne par ligne. Page sans layout pour
// éviter toute interférence avec la feuille de style et les scripts
// Webflow Veloura.
// =====================================================================
---

<!doctype html>
<html data-wf-domain="veloura-hotel-template.webflow.io" data-wf-page="68d6a56b32400004b53bc0d7" data-wf-site="68d6a56b32400004b53bc0e9" lang="en">
  <head>
