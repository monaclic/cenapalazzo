        position: relative;
        width: 100%;
        min-height: 620px;
      }
      .feeline-about-section .sticky-side-image {
        position: absolute;
        width: min(74%, 360px);
        overflow: hidden;
        background-color: #F7F5EE;
        border: 1px solid rgba(212, 175, 55, 0.22);
        box-shadow: 0 24px 56px rgba(42, 42, 42, 0.08);
        visibility: visible !important;
      }
      .feeline-about-section .sticky-side-image.is-1st {
        top: 0;
        left: 0;
        aspect-ratio: 4 / 5;
        transform: rotate(-4deg) !important;
      }
      .feeline-about-section .sticky-side-image.is-2nd {
        top: 10rem;
        right: 0;
        aspect-ratio: 3 / 4;
        transform: rotate(3deg) !important;
      }
      .feeline-about-section .sticky-side-image.is-3rd {
        left: 12%;
        bottom: 0;
        aspect-ratio: 5 / 4;
        transform: rotate(-1deg) !important;
      }
      .feeline-about-section .cover-image {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        visibility: visible !important;
      }
      .feeline-about-section .sticky-content-wrapper {
        display: flex;
        flex-direction: column;
        gap: 4.4rem;
        padding-top: 1.5rem;
      }
      .feeline-about-section .content-flex-block {
        max-width: 560px;
      }
      .feeline-about-section .heading.is-regular {
        color: #2A2A2A;
      }
