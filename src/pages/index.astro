    <script is:inline>
      (function () {
        var title = document.querySelector('#reservation .heading.is-cta-collage-title');
        if (!title) return;

        function markReady() {
          if (title.querySelector('.gsap_split_letter')) {
            title.classList.add('is-split-ready');
            return true;
          }
          return false;
        }

        if (markReady()) return;

        var observer = new MutationObserver(function () {
          if (markReady()) observer.disconnect();
        });
        observer.observe(title, { childList: true, subtree: true });

        window.setTimeout(function () {
          if (!markReady()) title.classList.add('is-split-ready');
          observer.disconnect();
        }, 1400);
      })();
    </script>

    <!-- Stabilise les mesures de la section A propos au premier passage. -->
    <script is:inline>
      (function () {
        var aboutSection = document.querySelector('.cpa-about-section');
        if (!aboutSection) return;

        function refreshMotionLayout() {
          if (window.cpaLenis && typeof window.cpaLenis.resize === 'function') {
            window.cpaLenis.resize();
          }
          if (typeof ScrollTrigger !== 'undefined') {
            ScrollTrigger.refresh(true);
            ScrollTrigger.update();
          }
        }

        function scheduleRefreshes() {
          [0, 160, 520, 1100].forEach(function (delay) {
            window.setTimeout(refreshMotionLayout, delay);
          });
        }

        aboutSection.querySelectorAll('img').forEach(function (img) {
          if (img.complete) return;
          img.addEventListener('load', scheduleRefreshes, { once: true });
          img.addEventListener('error', scheduleRefreshes, { once: true });
        });

        if ('IntersectionObserver' in window) {
          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                scheduleRefreshes();
                observer.disconnect();
              }
            });
          }, { rootMargin: '40% 0px 40% 0px', threshold: 0.01 });
          observer.observe(aboutSection);
        }

        if (document.readyState === 'complete') {
          scheduleRefreshes();
        } else {
          window.addEventListener('load', scheduleRefreshes, { once: true });
        }
        window.setTimeout(scheduleRefreshes, 1800);
      })();
    </script>

    <!-- Filet de sécurité ultra ciblé: retire uniquement le badge "Made in
         Webflow" injecté dynamiquement et le lien "Buy the template" Veloura
         (.important-link). On utilise un sélecteur attribut exact pour éviter
         de toucher les liens internes que Webflow réécrit. -->
    <script is:inline>
      (function () {
        function killTemplateChrome(root) {
          var sel = 'a[href="https://webflow.com?utm_campaign=brandjs"], a.important-link';
          var nodes = root.querySelectorAll(sel);
          nodes.forEach(function (n) { n.remove(); });
        }
        killTemplateChrome(document);
        var mo = new MutationObserver(function () { killTemplateChrome(document); });
        mo.observe(document.body, { childList: true, subtree: false });
        setTimeout(function () { mo.disconnect(); }, 15000);
      })();
    </script>

<!-- Force la disparition du loader après 2 secondes (l'animation Webflow
         IX2 ne s'exécute pas correctement ici car on a modifié la structure
         du preloader). -->
    <script is:inline>
      (function () {
        var loader = document.querySelector('.page-load-animation');
        if (!loader) return;
        function hide() {
          loader.style.transition = 'opacity 0.7s cubic-bezier(0.7, 0, 0.3, 1)';
          loader.style.opacity = '0';
          loader.style.pointerEvents = 'none';
          setTimeout(function () { loader.style.display = 'none'; }, 750);
        }
        if (document.readyState === 'complete') {
          setTimeout(hide, 2600);
        } else {
          window.addEventListener('load', function () { setTimeout(hide, 2600); }, { once: true });
        }
      })();
    </script>

