---
// =====================================================================
// COPIE VERBATIM INTÉGRALE DU TEMPLATE VELOURA HOTEL (page d'accueil).
// Sections, footer, scripts: tout est ici. L'adaptation à Cena a
// Palazzo se fera ensuite ligne par ligne. Page sans layout pour
// éviter toute interférence avec la feuille de style et les scripts
// Webflow Veloura.
// =====================================================================
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link href="https://cdn.prod.website-files.com" rel="preconnect" crossorigin="anonymous" />
    <title>Cena a Palazzo · 22 juin 2026 · Casino di Sanremo</title>
    <meta content="Cena a Palazzo réunit Monaco et Sanremo le 22 juin 2026 au Casino di Sanremo, autour d'une table signée Christian Garcia et d'un engagement pour le vivant." name="description" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <meta content="Astro" name="generator" />
    <meta name="robots" content="noindex, nofollow" />

    <link
      href="https://cdn.prod.website-files.com/68d6a56b32400004b53bc0e9/css/veloura-hotel-template.webflow.shared.b406b5f30.min.css"
      rel="stylesheet"
      type="text/css"
      crossorigin="anonymous"
    />

    <!-- ================================================================
         SURCHARGE PALETTE ET TYPOGRAPHIE
         Reskinne le template Veloura avec la charte Féeline officielle
         (planches transmises par le client). Light theme partout: ivoire,
         champagne, beige sable, or doré, or métallisé. Pas de sombre.
         Typographies: Cormorant Garamond pour le display et le brand,
         Montserrat pour le texte courant.
         ================================================================ -->
    <style>
      :root {
        /* Tokens primaires Veloura remappés en palette Féeline · all white */
        --_colors---brand-main-color: #D4AF37;       /* or doré · accents */
        --_colors---brand-dark-1:    #BFA46A;        /* or métallisé */
        --_colors---brand-dark-2:    #8A7530;        /* or assombri (hover) */
        --_colors---brand-dark-3:    #FFFFFF;        /* hero bg · blanc pur */
        --_colors---brand-dark-4:    #FFFFFF;        /* blanc pur */
        --_colors---brand-dark-5:    #FFFFFF;        /* blanc pur */
        --_colors---brand-dark-6:    #FFFFFF;        /* blanc pur */
        --_colors---brand-light-1:   #FFFFFF;        /* blanc */
        --_colors---brand-light-2:   #FFFFFF;        /* blanc */
        --_colors---brand-light-3:   #FFFFFF;        /* blanc pur */
        --_colors---brand-light-4:   #FFFFFF;        /* blanc pur */
        --_colors---brand-light-5:   #FFFFFF;        /* blanc pur */
        --_colors---brand-light-6:   #BFA46A;        /* or métallisé */
        --_colors---brand-color-10:  rgba(212, 175, 55, 0.10);
        --_colors---brand-color-20:  rgba(212, 175, 55, 0.20);
        --_colors---brand-color-40:  rgba(212, 175, 55, 0.40);
        --_colors---brand-color-light-20: rgba(255, 255, 255, 0.20);
        --_colors---brand-color-light-70: rgba(255, 255, 255, 0.70);
        --_colors---border-color:    rgba(212, 175, 55, 0.20);
        --_colors---white:           #FFFFFF;

        /* Body tokens · all white */
        --body-bg:         #FFFFFF;   /* blanc pur */
        --body-bg-dark:    #FFFFFF;   /* sections alternées · blanc pur */
        --body-font:       #2A2A2A;   /* encre · texte par défaut */
        --body-font-light: #BFA46A;   /* or métallisé · pour H1 hero, accents */

        /* Typographies Féeline */
        --_typography---sans-font:    "Montserrat", system-ui, sans-serif;
        --_typography---display-font: "Cormorant Garamond", Georgia, serif;
        --_typography---brand-font:   "Cormorant Garamond", Georgia, serif;
      }

      /* ================================================================
         OVERRIDES DE LISIBILITÉ
         Velour utilisait du texte clair (brand-light-1 à 5) sur fonds
         sombres. Passé en light theme, ces textes sont devenus invisibles.
         On force du texte sombre (encre) sur les éléments concernés.
         ================================================================ */
      .nav-link,
      .nav-small-link,
      .brand-logo-link,
      .brand-slogan,
      .highlights-section,
      .accomondation-wrapper,
      .accommodation-hero,
      .room-item,
      .room-list-title,
      .cta-content,
      .rooms-detail,
      .dining-offer,
      .breadcrumb-link,
      .is-light,
      .regular-link,
      .footer-text,
      .footer-slogan,
      .menu-link-text,
      .menu-small-text,
      .menu-address,
      .menu-small-title,
      .card-text-block,
      .paragraph-medium,
      .uppercase-text {
        color: #2A2A2A;
      }

      .nav-link:hover,
      .regular-link:hover,
      .footer-link:hover {
        color: #D4AF37;
      }

      /* Filets dorés (les regular-link-line étaient light-4 = beige) */
      .regular-link-line {
        background-color: #D4AF37;
      }
      .regular-link-icon {
        filter: brightness(0) saturate(100%) invert(72%) sepia(38%) saturate(810%) hue-rotate(0deg) brightness(95%) contrast(92%);
      }

      /* Wordmark Cena a Palazzo dans le nav header, remplace le logo Velour */
      .brand-wordmark {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 500;
        font-size: 1.4rem;
        color: #2A2A2A;
        line-height: 1;
        letter-spacing: 0.01em;
        white-space: nowrap;
      }

      /* Boutons CTA Velour · style outline. Fond blanc, contour or doré,
         texte encre centré. Léger fondu doré au survol. Pas de flèche, pas
         d'overlay slide IX2. */
      .button,
      .form-submit-button {
        background-color: #FFFFFF !important;
        color: #2A2A2A !important;
        border: 1px solid #BFA46A !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        text-align: center !important;
        transition: background-color 0.45s ease, color 0.45s ease, border-color 0.45s ease !important;
      }
      .button .button-text,
      .form-submit-button .button-text {
        width: 100% !important;
        text-align: center !important;
      }
      .button:hover,
      .form-submit-button:hover {
        background-color: rgba(212, 175, 55, 0.08) !important;
        border-color: #D4AF37 !important;
        color: #2A2A2A !important;
      }
      .button .button-text,
      .form-submit-button .button-text {
        color: #2A2A2A !important;
      }
      .button .button-bg,
      .form-submit-button .button-bg {
        display: none !important;
      }
      .button .button-icon-block,
      .button .button-icon,
      .form-submit-button .button-icon-block,
      .form-submit-button .button-icon {
        display: none !important;
      }
      :global(.button),
      :global(.form-submit-button) {
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        text-align: center !important;
        gap: 0 !important;
        padding-left: 1.35rem !important;
        padding-right: 1.35rem !important;
      }
      :global(.button .button-text),
      :global(.form-submit-button .button-text) {
        display: block !important;
        width: 100% !important;
        margin: 0 auto !important;
        text-align: center !important;
      }
      :global(.button .button-icon-block),
      :global(.button .button-icon),
      :global(.form-submit-button .button-icon-block),
      :global(.form-submit-button .button-icon) {
        display: none !important;
      }

      /* H1 du hero en or doré pour matcher les planches Féeline */
      .heading.is-home-hero-title {
        color: #BFA46A;
      }

      .cpa-poster-hero {
        min-height: 100svh;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        padding: clamp(7rem, 10vw, 10rem) clamp(1.25rem, 6vw, 6rem) clamp(3.5rem, 7vw, 5rem);
        background-color: #FFFFFF;
        isolation: isolate;
      }
      .cpa-poster-hero-image {
        position: absolute;
        top: 50%;
        right: clamp(-11rem, -10vw, -4rem);
        width: min(63vw, 920px);
        height: min(68vh, 640px);
        object-fit: contain;
        object-position: center right;
        transform: translateY(-50%);
        z-index: -2;
        filter: drop-shadow(0 34px 58px rgba(138, 117, 48, 0.18));
      }
      .cpa-poster-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(90deg, #FFFFFF 0%, rgba(255, 255, 255, 0.9) 25%, rgba(255, 255, 255, 0.22) 48%, rgba(255, 255, 255, 0) 72%),
          linear-gradient(0deg, #FFFFFF 0%, rgba(255, 255, 255, 0) 18%);
        z-index: -1;
      }
      .cpa-poster-hero::after {
        content: "";
        position: absolute;
        inset: 1.1rem;
        border: 1px solid rgba(191, 164, 106, 0.28);
        pointer-events: none;
        z-index: 0;
      }
      .cpa-poster-hero-content {
        width: min(100%, 760px);
        color: #2A2A2A;
        position: relative;
        z-index: 1;
      }
      .cpa-poster-hero-kicker {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        margin-bottom: 1.15rem;
        color: #8A7530;
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }
      .cpa-poster-hero-kicker::before {
        content: "";
        width: 2.8rem;
        height: 1px;
        background-color: rgba(212, 175, 55, 0.72);
      }
      .cpa-poster-hero-title {
        margin: 0;
        color: #2A2A2A;
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(4.6rem, 11vw, 10rem);
        font-style: italic;
        font-weight: 500;
        line-height: 0.86;
      }
      .cpa-poster-hero-subtitle {
        margin: 1.4rem 0 0;
        color: #8A7530;
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: clamp(0.86rem, 1.2vw, 1.05rem);
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .cpa-poster-hero-line {
        width: min(100%, 34rem);
        height: 1px;
        margin: 1.6rem 0;
        background: linear-gradient(90deg, rgba(212, 175, 55, 0.72), rgba(212, 175, 55, 0));
      }
      .cpa-poster-hero-copy {
        max-width: 40rem;
        margin: 0;
        color: rgba(42, 42, 42, 0.78);
        font-size: clamp(1rem, 1.25vw, 1.15rem);
        line-height: 1.75;
      }
      .cpa-poster-hero-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 1rem;
        margin-top: 2rem;
      }
      .cpa-poster-hero-actions .button {
        background-color: #FFFFFF !important;
        border-color: rgba(191, 164, 106, 0.72) !important;
      }
      .cpa-poster-hero-actions .regular-link {
        color: #2A2A2A !important;
        visibility: visible !important;
        opacity: 1 !important;
        transform: none !important;
      }
      .cpa-poster-hero-actions .regular-link-line {
        background-color: rgba(212, 175, 55, 0.88);
      }
      .cpa-poster-hero-actions .regular-link-icon {
        filter: brightness(0) saturate(100%) invert(72%) sepia(38%) saturate(810%) hue-rotate(0deg) brightness(95%) contrast(92%);
      }
      @media (max-width: 760px) {
        .cpa-poster-hero {
          align-items: center;
          justify-content: center;
          padding: 5.5rem 1.5rem 3.5rem;
          text-align: center;
        }
        .cpa-poster-hero::after {
          inset: 0.75rem;
        }
        .cpa-poster-hero::before {
          background: #FFFFFF;
        }
        /* Mobile : on retire totalement l'illustration. Trop chargee, pas
           luxe. Composition mobile = typographie pure, centree, beaucoup
           d'air. La facade reste pour le desktop ou elle a la place de
           respirer. */
        .cpa-poster-hero-image {
          display: none;
        }
        .cpa-poster-hero-content {
          width: 100%;
          max-width: 26rem;
          margin: 0 auto;
          padding-top: 0;
        }
        .cpa-poster-hero-kicker {
          justify-content: center;
        }
        .cpa-poster-hero-line {
          margin: 1.6rem auto;
        }
        .cpa-poster-hero-copy {
          margin: 0 auto;
        }
        .cpa-poster-hero-actions {
          justify-content: center;
        }
        .cpa-poster-hero-title {
          font-size: clamp(4rem, 19vw, 5.8rem);
        }
      }

      /* "Welcome" du loader en or doré sur fond ivoire */
      .preloader-text {
        color: #BFA46A;
      }
      /* Le loader n'a plus besoin d'un overlay sombre · on l'allège */
      .preloader-image-color {
        background-color: rgba(247, 245, 238, 0.15);
      }

      /* Loader · blason CP centré dans le cadre, sans crop, apparition chic */
      .preloader-image.is-blazon {
        object-fit: contain;
        object-position: center;
        background-color: #FFFFFF;
        animation: blazon-appear 2s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      @keyframes blazon-appear {
        0% {
          opacity: 0;
          transform: scale(0.85) translateY(15px);
          filter: blur(8px);
        }
        50% {
          opacity: 1;
          filter: blur(0);
        }
        100% {
          opacity: 1;
          transform: scale(1) translateY(0);
          filter: blur(0);
        }
      }
      /* Cache l'overlay quand on a un blason (pas une photo) */
      .preloader-image-trigger:has(.preloader-image.is-blazon) .preloader-image-color {
        display: none;
      }

      /* Slogan "Hotel Template" plus lisible */
      .slogan-text {
        color: #8A7530;
      }

      /* Logo Velour SVG · teinté en gris foncé en attendant le remplacement */
      .logo-image {
        filter: brightness(0) saturate(100%) invert(11%) sepia(0%) saturate(0%) hue-rotate(0deg) brightness(95%) contrast(85%);
      }

      /* Burger icon en encre */
      .burger-icon-line {
        background-color: #2A2A2A;
      }

      /* ================================================================
         MESH GRADIENTS et BLURRY BACKGROUNDS
         Les SVG locaux or doré rendaient un halo jaune disgracieux.
         On les masque entièrement · le fond ivoire pur est plus net
         et plus cérémoniel pour le registre Cena a Palazzo.
         ================================================================ */
      .mesh-bg,
      .mesh-bgs-wrapper,
      .mesh-bg-1-center,
      .mesh-bg-2-center,
      .mesh-bg-3-left,
      .mesh-bg-4-right,
      .room-blurry-bg,
      .collage-blurry-bg,
      [src*="bg-gradient-1"],
      [src*="bg-gradient-2"] {
        display: none !important;
      }

      /* ----- Sticky-title : on cale toutes les instances à 100vh
         (Velour default est 150lvh, ce qui cause un chevauchement entre
         la title sticky et le sticky-about en transition). ----- */
      .sticky-title-size {
        min-height: 100vh !important;
      }
      .sticky-title-size.has-illustration {
        position: relative;
      }
      .sticky-title-illustration {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: clamp(420px, 60vw, 900px);
        height: auto;
        object-fit: contain;
        z-index: 0;
        opacity: 0.32;
        pointer-events: none;
        mix-blend-mode: multiply;
      }
      .sticky-title-size.has-illustration .sticky-title-layout {
        position: relative;
        z-index: 2;
      }
      @media (max-width: 767px) {
        .sticky-title-illustration {
          opacity: 0.22;
        }
      }

      /* ================================================================
         GRAVURE FÉELINE INLINE · sibling de .accomondation-wrapper.
         Réduit la hauteur sticky-title-size Velour (150lvh par défaut,
         crée un énorme vide) à 100vh, et padding modéré sur la gravure.
         ================================================================ */
      .accomondation-wrapper .sticky-title-size {
        min-height: 100vh !important;
      }
      .cpa-about-section > .sticky-title-size {
        min-height: 100svh !important;
        height: auto !important;
        position: relative !important;
      }
      .cpa-about-section > .sticky-title-size .sticky-title-layout {
        position: relative !important;
        top: auto !important;
        transform: none !important;
      }
      .cpa-about-section > .large-top-padding {
        padding-top: clamp(2.5rem, 5vw, 4.5rem);
      }
      /* Desktop · resserre l'écart vertical entre le titre sticky
         "L'expérience / Au coeur du Casino…" et le bloc "Le lieu / Le geste
         culinaire / Le sens de la soirée" qui le suit. */
      @media (min-width: 768px) {
        .cpa-about-section > .sticky-title-size {
          min-height: auto !important;
          padding-block: clamp(5rem, 9vw, 8rem) clamp(0.5rem, 1vw, 1.25rem) !important;
        }
        .cpa-about-section > .large-top-padding {
          padding-top: 0;
        }
        /* Velour pose padding-top:40lvh sur sticky-content-wrapper pour
           laisser de la place a l'animation scroll des images laterales.
           Ici, image quasi statique, on resserre fortement. */
        .cpa-about-section .sticky-content-wrapper {
          padding-top: clamp(5rem, 8vw, 8rem) !important;
        }
      }
      /* Mobile : Velour laisse sticky-title-size a 100svh + sticky-content-wrapper
         a padding-top:5rem + image plan-de-table coincee hors ecran (scale 0.5,
         translate -80vw, GSAP n'animant pas en mobile portrait). Resultat : vide
         vertical enorme et thumbnail orpheline. On corrige sans toucher au desktop. */
      @media (max-width: 767px) {
        .cpa-about-section > .sticky-title-size {
          min-height: auto !important;
          padding-block: clamp(3.5rem, 12vw, 5rem) clamp(0.5rem, 2vw, 1.25rem) !important;
        }
        .cpa-about-section > .large-top-padding {
          padding-top: 0 !important;
        }
        .cpa-about-section .sticky-content-wrapper {
          padding-top: clamp(2rem, 6vw, 3.5rem) !important;
          padding-bottom: clamp(2rem, 6vw, 3.5rem) !important;
        }
        .cpa-about-section .sticky-side-images {
          display: none !important;
        }
      }
      .cpa-about-section .heading.is-sticky-title,
      .cpa-about-section .sticky-side-image,
      .cpa-about-section .cover-image,
      .cpa-about-section .uppercase-text,
      .cpa-about-section .button,
      .cpa-about-section .button-bg,
      .cpa-about-section .button-icon {
        visibility: visible !important;
      }
      .heading.is-sticky-title {
        visibility: visible !important;
      }
      :global(.heading.is-sticky-title > div),
      :global(.heading.is-sticky-title > span) {
        visibility: visible !important;
        opacity: 1 !important;
        transform: none !important;
        translate: none !important;
      }
      .feeline-engraving-inline {
        width: 100%;
        padding: 2rem 6vw 4rem 6vw;
        text-align: center;
      }
      .feeline-engraving-image {
        display: block;
        width: 100%;
        max-width: 720px;
        height: auto;
        margin: 0 auto 1.2rem auto;
      }
      .feeline-engraving-caption {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #BFA46A;
        margin: 0;
      }

      /* ================================================================
         SECTION PATRONAGE · éditorial sobre, prose continue.
         Wax seal CP comme ancre, deux paragraphes, pas de box.
         ================================================================ */
      .feeline-patronage-section {
        background-color: #FFFFFF;
        padding: 7rem 0 8rem 0;
        text-align: center;
      }
      .feeline-patronage-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 6vw;
      }
      .feeline-patronage-seal {
        display: block;
        width: clamp(140px, 14vw, 200px);
        height: auto;
        margin: 0 auto 3rem auto;
      }
      .feeline-patronage-heading {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-weight: 400;
        font-size: clamp(1.7rem, 2.6vw, 2.4rem);
        line-height: 1.3;
        color: #2A2A2A;
        margin: 0 0 2.5rem 0;
      }
      .feeline-patronage-heading em {
        font-style: italic;
        color: #BFA46A;
        display: block;
        margin-bottom: 0.4rem;
      }
      .feeline-patronage-body {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: 1.28rem;
        line-height: 1.75;
        color: #2A2A2A;
        margin: 0 auto 1.5rem auto;
        max-width: 52rem;
      }
      .feeline-patronage-body em {
        font-style: italic;
        color: #BFA46A;
      }
      .feeline-patronage-body:last-child {
        margin-bottom: 0;
      }
      .cpa-mobile-photo-strip {
        display: none;
      }
      @media (max-width: 767px) {
        .cpa-mobile-photo-strip {
          display: grid;
          grid-template-columns: minmax(0, 1fr) minmax(0, 0.78fr);
          gap: 0.75rem;
          padding: 0 1.25rem 4.25rem 1.25rem;
          background-color: #FFFFFF;
        }
        .cpa-mobile-photo-strip figure {
          margin: 0;
          overflow: hidden;
          border: 1px solid rgba(191, 164, 106, 0.28);
          background-color: #FFFFFF;
          box-shadow: 0 1.2rem 3rem rgba(42, 42, 42, 0.1);
        }
        .cpa-mobile-photo-strip figure:first-child {
          aspect-ratio: 4 / 5;
        }
        .cpa-mobile-photo-strip figure:nth-child(2) {
          aspect-ratio: 3 / 4;
          margin-top: 2.2rem;
        }
        .cpa-mobile-photo-strip img {
          display: block;
          width: 100%;
          height: 100%;
          object-fit: cover;
        }
      }

      /* ================================================================
         SECTION MENU FÉELINE · 4 cartes papier disposées en ligne,
         chacune représentant un plat. Effet papier ivoire avec ombre,
         filet doré, légère rotation aléatoire.
         ================================================================ */
      .feeline-menu-section {
        background-color: #FFFFFF;
        padding: 7rem 0;
        text-align: center;
      }
      .feeline-menu-header {
        max-width: 1100px;
        margin: 0 auto 4rem auto;
        padding: 0 6vw;
      }
      .feeline-eyebrow {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #BFA46A;
        margin: 0 0 1.5rem 0;
      }
      .feeline-menu-heading {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-weight: 400;
        font-size: clamp(2rem, 3.4vw, 3.4rem);
        line-height: 1.15;
        color: #2A2A2A;
        margin: 0 0 1.5rem 0;
      }
      .feeline-menu-heading em {
        font-style: italic;
        color: #BFA46A;
      }
      .feeline-menu-intro {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-size: 1.28rem;
        line-height: 1.7;
        color: #2A2A2A;
        opacity: 0.8;
        max-width: 48rem;
        margin: 0 auto 2rem auto;
      }
      .feeline-filet {
        width: 50px;
        height: 1px;
        background-color: #D4AF37;
        margin: 0 auto;
      }
      /* ----- Les 4 cartes papier ----- */
      .feeline-menu-cards {
        max-width: 1280px;
        margin: 0 auto 4rem auto;
        padding: 0 6vw;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
      }
      .feeline-card {
        position: relative;
        padding: 3rem 1.6rem 2.2rem;
        background-color: #FCFAF3;
        background-image:
          radial-gradient(ellipse at 30% 20%, rgba(212, 175, 55, 0.06) 0%, transparent 60%),
          radial-gradient(ellipse at 70% 80%, rgba(212, 175, 55, 0.05) 0%, transparent 55%),
          repeating-linear-gradient(0deg, rgba(212, 175, 55, 0.015) 0px, rgba(212, 175, 55, 0.015) 1px, transparent 1px, transparent 3px);
        border: 1px solid rgba(212, 175, 55, 0.22);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.8) inset,
          0 14px 30px rgba(42, 42, 42, 0.07),
          0 3px 8px rgba(42, 42, 42, 0.04);
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s;
      }
      .feeline-card::before {
        content: "";
        position: absolute;
        top: 1.4rem;
        left: 50%;
        transform: translateX(-50%);
        width: 32px;
        height: 1px;
        background-color: #D4AF37;
      }
      .feeline-card:hover {
        transform: translateY(-6px);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.8) inset,
          0 24px 52px rgba(212, 175, 55, 0.20),
          0 6px 16px rgba(42, 42, 42, 0.08);
        z-index: 3;
      }
      .feeline-card-num {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 500;
        font-size: 1.7rem;
        color: #BFA46A;
        margin-top: 1.2rem;
        line-height: 1;
      }
      .feeline-card-label {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.62rem;
        font-weight: 500;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #2A2A2A;
        opacity: 0.55;
        margin: 0.5rem 0 1rem 0;
      }
      .feeline-card-dish {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 400;
        font-size: 1.4rem;
        line-height: 1.25;
        color: #2A2A2A;
        margin: 0;
      }
      .feeline-card-detail {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        color: #2A2A2A;
        opacity: 0.6;
        margin: 0.5rem 0 0 0;
        font-style: italic;
      }
      .feeline-menu-pairing {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #BFA46A;
        margin: 0;
      }
      @media (max-width: 991px) {
        .feeline-menu-cards {
          grid-template-columns: repeat(2, 1fr);
          gap: 1.5rem;
        }
      }
      @media (max-width: 600px) {
        .feeline-menu-cards {
          grid-template-columns: 1fr;
          max-width: 380px;
        }
      }

      /* ================================================================
         SECTION CONFIDENCES + CARTE DE CORRESPONDANCE
         Diptyque éditorial inspiré du carton d'invitation gravé.
         Questions pratiques numérotées en chiffres romains à gauche,
         carte papier vellum à droite avec sous lignes pointillées.
         ================================================================ */
      .feeline-faq-section {
        background-color: #FFFFFF;
        padding: 8rem 0 9rem 0;
        position: relative;
        overflow: hidden;
      }
      .feeline-faq-section::before,
      .feeline-faq-section::after {
        content: "";
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        width: clamp(80px, 9vw, 120px);
        height: 1px;
        background-color: #D4AF37;
        opacity: 0.55;
      }
      .feeline-faq-section::before { top: 4.5rem; }
      .feeline-faq-section::after  { bottom: 4.5rem; }
      .feeline-faq-container {
        max-width: 1240px;
        margin: 0 auto;
        padding: 0 6vw;
        position: relative;
      }
      .feeline-faq-header {
        text-align: center;
        margin-bottom: 5.5rem;
        max-width: 720px;
        margin-left: auto;
        margin-right: auto;
      }
      .feeline-faq-eyebrow {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.66rem;
        font-weight: 500;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: #BFA46A;
        margin: 0 0 1.4rem 0;
      }
      .feeline-faq-heading {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 400;
        font-size: clamp(2.6rem, 5vw, 4.4rem);
        line-height: 1;
        color: #2A2A2A;
        margin: 0 0 1.4rem 0;
        letter-spacing: -0.005em;
      }
      .feeline-faq-subtitle {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-size: clamp(1.05rem, 1.3vw, 1.2rem);
        color: #2A2A2A;
        opacity: 0.65;
        line-height: 1.55;
        margin: 0;
      }
      /* ----- Questions pratiques éditoriales ----- */
      .feeline-faq-list {
        display: flex;
        flex-direction: column;
        max-width: 820px;
        margin: 0 auto;
      }
      .feeline-faq-item {
        border-top: 1px solid rgba(191, 164, 106, 0.4);
        padding: 1.9rem 0;
      }
      .feeline-faq-item:last-child {
        border-bottom: 1px solid rgba(191, 164, 106, 0.4);
      }
      .feeline-faq-item > summary {
        list-style: none;
        cursor: pointer;
        display: grid;
        grid-template-columns: 3.4rem 1fr auto;
        align-items: baseline;
        gap: 1.6rem;
      }
      .feeline-faq-item > summary::-webkit-details-marker { display: none; }
      .feeline-faq-numeral {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 500;
        font-size: 1.75rem;
        color: #BFA46A;
        line-height: 1;
        transition: color 0.3s ease;
        letter-spacing: 0.02em;
      }
      .feeline-faq-question {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(1.2rem, 1.55vw, 1.55rem);
        font-weight: 400;
        font-style: italic;
        color: #2A2A2A;
        line-height: 1.35;
        transition: color 0.3s ease;
      }
      .feeline-faq-toggle {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-size: 1rem;
        color: #BFA46A;
        white-space: nowrap;
        align-self: center;
        opacity: 0.7;
        transition: opacity 0.3s ease, color 0.3s ease;
      }
      .feeline-faq-item[open] .feeline-faq-toggle::before { content: "Refermer"; }
      .feeline-faq-item:not([open]) .feeline-faq-toggle::before { content: "Lire la réponse"; }
      .feeline-faq-item > summary:hover .feeline-faq-numeral,
      .feeline-faq-item > summary:hover .feeline-faq-toggle,
      .feeline-faq-item > summary:hover .feeline-faq-question {
        color: #BFA46A;
      }
      .feeline-faq-item > summary:hover .feeline-faq-toggle { opacity: 1; }
      .feeline-faq-answer-wrap {
        display: grid;
        grid-template-columns: 3.4rem 1fr;
        gap: 1.6rem;
        margin-top: 1.1rem;
      }
      .feeline-faq-answer {
        grid-column: 2;
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: 1.12rem;
        line-height: 1.75;
        color: #2A2A2A;
        opacity: 0.78;
        margin: 0;
        max-width: 38rem;
        padding-left: 1.4rem;
        border-left: 1px solid rgba(212, 175, 55, 0.5);
      }
      .feeline-faq-answer a {
        color: #BFA46A;
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
      }
      .feeline-faq-answer a:hover { color: #D4AF37; }

      /* ================================================================
         SECTION LE LIEU · grille éditoriale 2 colonnes, sans dépendance
         aux animations Velour sticky-about (qui ne supportent qu'une
         instance par page). Photos à gauche, 3 blocs info à droite.
         ================================================================ */
      .feeline-lieu-section {
        background-color: #FFFFFF;
        padding: 8rem 0 9rem 0;
        position: relative;
        overflow: hidden;
      }
      .feeline-lieu-section::before,
      .feeline-lieu-section::after {
        content: "";
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        width: clamp(80px, 9vw, 120px);
        height: 1px;
        background-color: #D4AF37;
        opacity: 0.55;
      }
      .feeline-lieu-section::before { top: 4.5rem; }
      .feeline-lieu-section::after  { bottom: 4.5rem; }
      .feeline-lieu-container {
        max-width: 1240px;
        margin: 0 auto;
        padding: 0 6vw;
      }
      .feeline-lieu-header {
        text-align: center;
        margin: 0 auto 5rem auto;
        max-width: 720px;
      }
      .feeline-lieu-layout {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 5rem;
        align-items: start;
      }
      .feeline-lieu-images {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .feeline-lieu-image {
        width: 100%;
        aspect-ratio: 4 / 5;
        object-fit: cover;
        display: block;
      }
      .feeline-lieu-blocks {
        display: flex;
        flex-direction: column;
        gap: 3.2rem;
      }
      .feeline-lieu-block {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }
      .feeline-lieu-block-eyebrow {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.62rem;
        font-weight: 500;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #BFA46A;
        margin: 0;
      }
      .feeline-lieu-block-title {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 400;
        font-size: clamp(1.4rem, 2vw, 1.85rem);
        line-height: 1.25;
        color: #2A2A2A;
        margin: 0;
      }
      .feeline-lieu-block-divider {
        width: 32px;
        height: 1px;
        background-color: #D4AF37;
        margin: 0.4rem 0 0.3rem 0;
      }
      .feeline-lieu-block-text {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: 1.12rem;
        line-height: 1.75;
        color: #2A2A2A;
        opacity: 0.78;
        margin: 0;
      }
      @media (max-width: 991px) {
        .feeline-lieu-layout {
          grid-template-columns: 1fr;
          gap: 3.5rem;
        }
        .feeline-lieu-images {
          flex-direction: row;
        }
      }
      @media (max-width: 600px) {
        .feeline-lieu-section { padding: 5rem 0 6rem 0; }
        .feeline-lieu-section::before { top: 2.5rem; }
        .feeline-lieu-section::after  { bottom: 2.5rem; }
        .feeline-lieu-images { flex-direction: column; }
      }

      /* ================================================================
         SECTION A PROPOS · adaptation proche de la section Velour fournie.
         On garde la structure sticky-about, avec des overrides de stabilité
         pour éviter les positions invisibles avant animation Webflow.
         ================================================================ */
      .feeline-about-section {
        background-color: #FFFFFF;
        position: relative;
        overflow: hidden;
      }
      .feeline-about-section .sticky-title-layout {
        color: #2A2A2A;
      }
      .feeline-about-section .heading.is-sticky-title {
        color: #2A2A2A;
        visibility: visible !important;
        opacity: 1 !important;
        transform: none !important;
      }
      .feeline-about-section .heading.is-sticky-title em {
        color: #BFA46A;
        font-style: italic;
      }
      :global(.feeline-about-section .heading.is-sticky-title .gsap_split_word) {
        opacity: 1 !important;
        transform: none !important;
        translate: none !important;
      }
      .feeline-about-section .circle-button {
        border-color: rgba(191, 164, 106, 0.55);
        background-color: #FFFFFF;
      }
      .feeline-about-section .large-top-padding {
        padding-top: 7rem;
        padding-bottom: 9rem;
      }
      .feeline-about-section .sticky-about {
        display: grid;
        grid-template-columns: minmax(280px, 0.9fr) minmax(0, 1.1fr);
        gap: clamp(3rem, 7vw, 7rem);
        align-items: start;
      }
      .feeline-about-section .sticky-side-images {
        position: sticky;
        top: 8rem;
        min-height: 620px;
      }
      .feeline-about-section .sticky-side-images-wrapper {
        position: relative;
        width: 100%;
        min-height: 620px;
      }
      .feeline-about-section .sticky-side-image {
        position: absolute;
        width: min(74%, 360px);
        overflow: hidden;
        background-color: #F7F5EE;
        border: 1px solid rgba(212, 175, 55, 0.22);
        box-shadow: 0 24px 56px rgba(42, 42, 42, 0.08);
        visibility: visible !important;
      }
      .feeline-about-section .sticky-side-image.is-1st {
        top: 0;
        left: 0;
        aspect-ratio: 4 / 5;
        transform: rotate(-4deg) !important;
      }
      .feeline-about-section .sticky-side-image.is-2nd {
        top: 10rem;
        right: 0;
        aspect-ratio: 3 / 4;
        transform: rotate(3deg) !important;
      }
      .feeline-about-section .sticky-side-image.is-3rd {
        left: 12%;
        bottom: 0;
        aspect-ratio: 5 / 4;
        transform: rotate(-1deg) !important;
      }
      .feeline-about-section .cover-image {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        visibility: visible !important;
      }
      .feeline-about-section .sticky-content-wrapper {
        display: flex;
        flex-direction: column;
        gap: 4.4rem;
        padding-top: 1.5rem;
      }
      .feeline-about-section .content-flex-block {
        max-width: 560px;
      }
      .feeline-about-section .heading.is-regular {
        color: #2A2A2A;
      }
      .feeline-about-section .paragraph-small {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: 1.16rem;
        line-height: 1.76;
        color: #2A2A2A;
        opacity: 0.78;
      }
      .feeline-about-section .button {
        margin-top: 1.4rem;
      }
      @media (max-width: 991px) {
        .feeline-about-section .large-top-padding {
          padding-top: 5rem;
          padding-bottom: 7rem;
        }
        .feeline-about-section .sticky-about {
          grid-template-columns: 1fr;
          gap: 4rem;
        }
        .feeline-about-section .sticky-side-images,
        .feeline-about-section .sticky-side-images-wrapper {
          position: relative;
          top: auto;
          min-height: auto;
        }
        .feeline-about-section .sticky-side-images-wrapper {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 1rem;
        }
        .feeline-about-section .sticky-side-image {
          position: relative;
          top: auto !important;
          right: auto !important;
          bottom: auto !important;
          left: auto !important;
          width: 100%;
          aspect-ratio: 4 / 5;
          transform: none !important;
        }
      }
      @media (max-width: 600px) {
        .feeline-about-section .sticky-title-size {
          min-height: 86vh !important;
        }
        .feeline-about-section .sticky-side-images-wrapper {
          grid-template-columns: 1fr;
        }
        .feeline-about-section .content-flex-block {
          max-width: none;
        }
      }

      @media (max-width: 991px) {
        .feeline-faq-item > summary {
          grid-template-columns: 2.2rem 1fr auto;
          gap: 1.1rem;
        }
        .feeline-faq-answer-wrap {
          grid-template-columns: 2.2rem 1fr;
          gap: 1.1rem;
        }
        .feeline-faq-numeral { font-size: 1.4rem; }
      }
      @media (max-width: 600px) {
        .feeline-faq-section { padding: 5rem 0 6rem 0; }
        .feeline-faq-section::before { top: 2.5rem; }
        .feeline-faq-section::after  { bottom: 2.5rem; }
        .feeline-faq-toggle { display: none; }
        .feeline-faq-item > summary {
          grid-template-columns: 1.8rem 1fr;
        }
      }

      /* Section "is-dark" Velour: bg blanc pur, texte encre */
      .section.is-dark {
        background-color: #FFFFFF;
        color: #2A2A2A;
      }
      .section.is-dark *:not(.regular-link):not(.regular-link-line):not(.button):not(.dot):not(.dot-animation) {
        color: inherit;
      }

      /* Section with-bg-gradient-3 · bg blanc uni */
      .section.with-bg-gradient-3 {
        background: #FFFFFF;
      }

      @media (max-width: 767px) {
        html.w-mod-js #reservation .heading.is-cta-collage-title {
          visibility: hidden;
        }
        html.w-mod-js #reservation .heading.is-cta-collage-title.is-split-ready {
          visibility: visible;
        }
      }

      /* Footer · bg champagne Féeline sur toute la hauteur, texte encre */
      .footer,
      .footer-cta,
      .footer-bg {
        background-color: #EFE6D3 !important;
      }
      .footer-bg {
        background-color: transparent !important;
      }
      .footer-link {
        color: #2A2A2A;
      }
      .footer-link:hover {
        color: #D4AF37;
      }
      .cpa-footer {
        position: relative;
        overflow: hidden;
        padding: clamp(5rem, 9vw, 8rem) clamp(1.25rem, 6vw, 6rem) 2rem;
        background:
          linear-gradient(180deg, #FFFFFF 0%, #EFE6D3 32%, #E7D7B9 100%) !important;
        color: #2A2A2A;
      }
      .cpa-footer::before {
        content: "";
        position: absolute;
        inset: 1rem;
        border: 1px solid rgba(191, 164, 106, 0.32);
        pointer-events: none;
      }
      .cpa-footer-cta {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: clamp(1.75rem, 3vw, 2.75rem);
        max-width: 1180px;
        margin: 0 auto clamp(4rem, 8vw, 7rem);
      }
      .cpa-footer-eyebrow,
      .cpa-footer-label {
        margin: 0 0 1rem;
        color: #8A7530;
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }
      .cpa-footer-title {
        margin: 0;
        max-width: 780px;
        color: #2A2A2A;
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(4rem, 9vw, 8.5rem);
        font-style: italic;
        font-weight: 500;
        line-height: 0.98;
        padding-bottom: 0.08em;
      }
      .cpa-footer-copy {
        margin: 1.4rem 0 0;
        max-width: 34rem;
        color: rgba(42, 42, 42, 0.72);
        font-size: clamp(1rem, 1.2vw, 1.12rem);
        line-height: 1.7;
      }
      .cpa-footer-main {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1.1fr 1fr 1fr;
        gap: clamp(1.5rem, 4vw, 4rem);
        max-width: 1180px;
        margin: 0 auto;
        padding-top: clamp(2rem, 4vw, 3.5rem);
        border-top: 1px solid rgba(191, 164, 106, 0.36);
      }
      .cpa-footer-block {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }
      .cpa-footer-value {
        margin: 0;
        color: #2A2A2A;
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(1.8rem, 3vw, 2.8rem);
        font-weight: 500;
        line-height: 1.05;
      }
      .cpa-footer-text {
        margin: 0.9rem 0 0;
        color: rgba(42, 42, 42, 0.72);
        font-size: 0.98rem;
        line-height: 1.65;
      }
      .cpa-footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem 1.2rem;
        margin-top: 1.2rem;
      }
      .cpa-footer-link {
        color: #2A2A2A;
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        text-decoration: none;
      }
      .cpa-footer-link:hover {
        color: #8A7530;
      }
      .cpa-footer-bottom {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        max-width: 1180px;
        margin: clamp(3rem, 6vw, 5rem) auto 0;
        padding-top: 1.25rem;
        border-top: 1px solid rgba(42, 42, 42, 0.12);
        color: rgba(42, 42, 42, 0.62);
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
