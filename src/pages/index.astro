---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
---

<Base>
  <Nav />
  <Hero />

  <section id="patronage" class="bg-ivoire py-section">
    <div class="max-w-ceremonie mx-auto px-6 text-center">
      <p class="font-sans text-[0.65rem] tracking-ceremonial uppercase text-orMetallise">À venir</p>
      <h2 class="mt-6 font-serif font-light text-4xl md:text-5xl tracking-tightish">
        Sections suivantes en cours d'intégration
      </h2>
      <div class="mt-10 w-20 h-px bg-orDore mx-auto"></div>
      <p class="mt-10 font-sans text-sm text-encre/70 max-w-prose mx-auto">
        Cette zone accueillera progressivement le patronage, le dîner, le menu signé du chef Christian Garcia, le programme de la soirée, le Casino di Sanremo, la galerie et le pied de page institutionnel.
      </p>
    </div>
  </section>
</Base>
