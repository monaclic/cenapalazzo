---
// =====================================================================
// COPIE VERBATIM INTÉGRALE DU TEMPLATE VELOURA HOTEL (page d'accueil).
// Sections, footer, scripts: tout est ici. L'adaptation à Cena a
// Palazzo se fera ensuite ligne par ligne. Page sans layout pour
// éviter toute interférence avec la feuille de style et les scripts
// Webflow Veloura.
// =====================================================================
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link href="https://cdn.prod.website-files.com" rel="preconnect" crossorigin="anonymous" />
    <title>Cena a Palazzo · 22 juin 2026 · Casino di Sanremo</title>
    <meta content="Dîner de gala caritatif au Casino di Sanremo le 22 juin 2026, sous le haut patronage de S.A.S. le Prince Albert II de Monaco, au bénéfice de la Fondation Prince Albert II de Monaco." name="description" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <meta content="Astro" name="generator" />
    <meta name="robots" content="noindex, nofollow" />

    <link
      href="https://cdn.prod.website-files.com/68d6a56b32400004b53bc0e9/css/veloura-hotel-template.webflow.shared.b406b5f30.min.css"
      rel="stylesheet"
      type="text/css"
      crossorigin="anonymous"
    />

    <!-- ================================================================
         SURCHARGE PALETTE ET TYPOGRAPHIE
         Reskinne le template Veloura avec la charte Féeline officielle
         (planches transmises par le client). Light theme partout: ivoire,
         champagne, beige sable, or doré, or métallisé. Pas de sombre.
         Typographies: Cormorant Garamond pour le display et le brand,
         Montserrat pour le texte courant.
         ================================================================ -->
    <style>
      :root {
        /* Tokens primaires Veloura remappés en palette Féeline · all white */
        --_colors---brand-main-color: #D4AF37;       /* or doré · accents */
        --_colors---brand-dark-1:    #BFA46A;        /* or métallisé */
        --_colors---brand-dark-2:    #8A7530;        /* or assombri (hover) */
        --_colors---brand-dark-3:    #FFFFFF;        /* hero bg · blanc pur */
        --_colors---brand-dark-4:    #FFFFFF;        /* blanc pur */
        --_colors---brand-dark-5:    #FFFFFF;        /* blanc pur */
        --_colors---brand-dark-6:    #FFFFFF;        /* blanc pur */
        --_colors---brand-light-1:   #FFFFFF;        /* blanc */
        --_colors---brand-light-2:   #FFFFFF;        /* blanc */
        --_colors---brand-light-3:   #FFFFFF;        /* blanc pur */
        --_colors---brand-light-4:   #FFFFFF;        /* blanc pur */
        --_colors---brand-light-5:   #FFFFFF;        /* blanc pur */
        --_colors---brand-light-6:   #BFA46A;        /* or métallisé */
        --_colors---brand-color-10:  rgba(212, 175, 55, 0.10);
        --_colors---brand-color-20:  rgba(212, 175, 55, 0.20);
        --_colors---brand-color-40:  rgba(212, 175, 55, 0.40);
        --_colors---brand-color-light-20: rgba(255, 255, 255, 0.20);
        --_colors---brand-color-light-70: rgba(255, 255, 255, 0.70);
        --_colors---border-color:    rgba(212, 175, 55, 0.20);
        --_colors---white:           #FFFFFF;

        /* Body tokens · all white */
        --body-bg:         #FFFFFF;   /* blanc pur */
        --body-bg-dark:    #FFFFFF;   /* sections alternées · blanc pur */
        --body-font:       #2A2A2A;   /* encre · texte par défaut */
        --body-font-light: #BFA46A;   /* or métallisé · pour H1 hero, accents */

        /* Typographies Féeline */
        --_typography---sans-font:    "Montserrat", system-ui, sans-serif;
        --_typography---display-font: "Cormorant Garamond", Georgia, serif;
        --_typography---brand-font:   "Cormorant Garamond", Georgia, serif;
      }

      /* ================================================================
         OVERRIDES DE LISIBILITÉ
         Velour utilisait du texte clair (brand-light-1 à 5) sur fonds
         sombres. Passé en light theme, ces textes sont devenus invisibles.
         On force du texte sombre (encre) sur les éléments concernés.
         ================================================================ */
      .nav-link,
      .nav-small-link,
      .brand-logo-link,
      .brand-slogan,
      .highlights-section,
      .accomondation-wrapper,
      .accommodation-hero,
      .room-item,
      .room-list-title,
      .cta-content,
      .rooms-detail,
      .dining-offer,
      .breadcrumb-link,
      .is-light,
      .regular-link,
      .footer-text,
      .footer-slogan,
      .menu-link-text,
      .menu-small-text,
      .menu-address,
      .menu-small-title,
      .card-text-block,
      .paragraph-medium,
      .uppercase-text {
        color: #2A2A2A;
      }

      .nav-link:hover,
      .regular-link:hover,
      .footer-link:hover {
        color: #D4AF37;
      }

      /* Filets dorés (les regular-link-line étaient light-4 = beige) */
      .regular-link-line {
        background-color: #D4AF37;
      }
      .regular-link-icon {
        filter: brightness(0) saturate(100%) invert(72%) sepia(38%) saturate(810%) hue-rotate(0deg) brightness(95%) contrast(92%);
      }

      /* Wordmark Cena a Palazzo dans le nav header, remplace le logo Velour */
      .brand-wordmark {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 500;
        font-size: 1.4rem;
        color: #2A2A2A;
        line-height: 1;
        letter-spacing: 0.01em;
        white-space: nowrap;
      }

      /* Boutons CTA Velour · style outline. Fond blanc, contour or doré,
         texte encre centré. Léger fondu doré au survol. Pas de flèche, pas
         d'overlay slide IX2. */
      .button,
      .form-submit-button {
        background-color: #FFFFFF !important;
        color: #2A2A2A !important;
        border: 1px solid #BFA46A !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        text-align: center !important;
        transition: background-color 0.45s ease, color 0.45s ease, border-color 0.45s ease !important;
      }
      .button .button-text,
      .form-submit-button .button-text {
        width: 100% !important;
        text-align: center !important;
      }
      .button:hover,
      .form-submit-button:hover {
        background-color: rgba(212, 175, 55, 0.08) !important;
        border-color: #D4AF37 !important;
        color: #2A2A2A !important;
      }
      .button .button-text,
      .form-submit-button .button-text {
        color: #2A2A2A !important;
      }
      .button .button-bg,
      .form-submit-button .button-bg {
        display: none !important;
      }
      .button .button-icon-block,
      .button .button-icon,
      .form-submit-button .button-icon-block,
      .form-submit-button .button-icon {
        display: none !important;
      }
      :global(.button),
      :global(.form-submit-button) {
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        text-align: center !important;
        gap: 0 !important;
        padding-left: 1.35rem !important;
        padding-right: 1.35rem !important;
      }
      :global(.button .button-text),
      :global(.form-submit-button .button-text) {
        display: block !important;
        width: 100% !important;
        margin: 0 auto !important;
        text-align: center !important;
      }
      :global(.button .button-icon-block),
      :global(.button .button-icon),
      :global(.form-submit-button .button-icon-block),
      :global(.form-submit-button .button-icon) {
        display: none !important;
      }

      /* H1 du hero en or doré pour matcher les planches Féeline */
      .heading.is-home-hero-title {
        color: #BFA46A;
      }

      /* "Welcome" du loader en or doré sur fond ivoire */
      .preloader-text {
        color: #BFA46A;
      }
      /* Le loader n'a plus besoin d'un overlay sombre · on l'allège */
      .preloader-image-color {
        background-color: rgba(247, 245, 238, 0.15);
      }

      /* Loader · blason CP centré dans le cadre, sans crop, apparition chic */
      .preloader-image.is-blazon {
        object-fit: contain;
        object-position: center;
        background-color: #FFFFFF;
        animation: blazon-appear 2s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      @keyframes blazon-appear {
        0% {
          opacity: 0;
          transform: scale(0.85) translateY(15px);
          filter: blur(8px);
        }
        50% {
          opacity: 1;
          filter: blur(0);
        }
        100% {
          opacity: 1;
          transform: scale(1) translateY(0);
          filter: blur(0);
        }
      }
      /* Cache l'overlay quand on a un blason (pas une photo) */
      .preloader-image-trigger:has(.preloader-image.is-blazon) .preloader-image-color {
        display: none;
      }

      /* Slogan "Hotel Template" plus lisible */
      .slogan-text {
        color: #8A7530;
      }

      /* Logo Velour SVG · teinté en gris foncé en attendant le remplacement */
      .logo-image {
        filter: brightness(0) saturate(100%) invert(11%) sepia(0%) saturate(0%) hue-rotate(0deg) brightness(95%) contrast(85%);
      }

      /* Burger icon en encre */
      .burger-icon-line {
        background-color: #2A2A2A;
      }

      /* ================================================================
         MESH GRADIENTS et BLURRY BACKGROUNDS
         Les SVG locaux or doré rendaient un halo jaune disgracieux.
         On les masque entièrement · le fond ivoire pur est plus net
         et plus cérémoniel pour le registre Cena a Palazzo.
         ================================================================ */
      .mesh-bg,
      .mesh-bgs-wrapper,
      .mesh-bg-1-center,
      .mesh-bg-2-center,
      .mesh-bg-3-left,
      .mesh-bg-4-right,
      .room-blurry-bg,
      .collage-blurry-bg,
      [src*="bg-gradient-1"],
      [src*="bg-gradient-2"] {
        display: none !important;
      }

      /* ----- Sticky-title : on cale toutes les instances à 100vh
         (Velour default est 150lvh, ce qui cause un chevauchement entre
         la title sticky et le sticky-about en transition). ----- */
      .sticky-title-size {
        min-height: 100vh !important;
      }
      .sticky-title-size.has-illustration {
        position: relative;
      }
      .sticky-title-illustration {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: clamp(420px, 60vw, 900px);
        height: auto;
        object-fit: contain;
        z-index: 0;
        opacity: 0.32;
        pointer-events: none;
        mix-blend-mode: multiply;
      }
      .sticky-title-size.has-illustration .sticky-title-layout {
        position: relative;
        z-index: 2;
      }
      @media (max-width: 767px) {
        .sticky-title-illustration {
          opacity: 0.22;
        }
      }

      /* ================================================================
         GRAVURE FÉELINE INLINE · sibling de .accomondation-wrapper.
         Réduit la hauteur sticky-title-size Velour (150lvh par défaut,
         crée un énorme vide) à 100vh, et padding modéré sur la gravure.
         ================================================================ */
      .accomondation-wrapper .sticky-title-size {
        min-height: 100vh !important;
      }
      .cpa-about-section > .sticky-title-size {
        min-height: 100svh !important;
        height: auto !important;
        position: relative !important;
      }
      .cpa-about-section > .sticky-title-size .sticky-title-layout {
        position: relative !important;
        top: auto !important;
        transform: none !important;
      }
      .cpa-about-section > .large-top-padding {
        padding-top: clamp(2.5rem, 5vw, 4.5rem);
      }
      .cpa-about-section .heading.is-sticky-title,
      .cpa-about-section .sticky-side-image,
      .cpa-about-section .cover-image,
      .cpa-about-section .uppercase-text,
      .cpa-about-section .button,
      .cpa-about-section .button-bg,
      .cpa-about-section .button-icon {
        visibility: visible !important;
      }
      .heading.is-sticky-title {
        visibility: visible !important;
      }
      :global(.heading.is-sticky-title > div),
      :global(.heading.is-sticky-title > span) {
        visibility: visible !important;
        opacity: 1 !important;
        transform: none !important;
        translate: none !important;
      }
      .feeline-engraving-inline {
        width: 100%;
        padding: 2rem 6vw 4rem 6vw;
        text-align: center;
      }
      .feeline-engraving-image {
        display: block;
        width: 100%;
        max-width: 720px;
        height: auto;
        margin: 0 auto 1.2rem auto;
      }
      .feeline-engraving-caption {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #BFA46A;
        margin: 0;
      }

      /* ================================================================
         SECTION PATRONAGE · éditorial sobre, prose continue.
         Wax seal CP comme ancre, deux paragraphes, pas de box.
         ================================================================ */
      .feeline-patronage-section {
        background-color: #FFFFFF;
        padding: 7rem 0 8rem 0;
        text-align: center;
      }
      .feeline-patronage-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 6vw;
      }
      .feeline-patronage-seal {
        display: block;
        width: clamp(140px, 14vw, 200px);
        height: auto;
        margin: 0 auto 3rem auto;
      }
      .feeline-patronage-heading {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-weight: 400;
        font-size: clamp(1.7rem, 2.6vw, 2.4rem);
        line-height: 1.3;
        color: #2A2A2A;
        margin: 0 0 2.5rem 0;
      }
      .feeline-patronage-heading em {
        font-style: italic;
        color: #BFA46A;
        display: block;
        margin-bottom: 0.4rem;
      }
      .feeline-patronage-body {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: 1.28rem;
        line-height: 1.75;
        color: #2A2A2A;
        margin: 0 auto 1.5rem auto;
        max-width: 52rem;
      }
      .feeline-patronage-body em {
        font-style: italic;
        color: #BFA46A;
      }
      .feeline-patronage-body:last-child {
        margin-bottom: 0;
      }

      /* ================================================================
         SECTION MENU FÉELINE · 4 cartes papier disposées en ligne,
         chacune représentant un plat. Effet papier ivoire avec ombre,
         filet doré, légère rotation aléatoire.
         ================================================================ */
      .feeline-menu-section {
        background-color: #FFFFFF;
        padding: 7rem 0;
        text-align: center;
      }
      .feeline-menu-header {
        max-width: 1100px;
        margin: 0 auto 4rem auto;
        padding: 0 6vw;
      }
      .feeline-eyebrow {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #BFA46A;
        margin: 0 0 1.5rem 0;
      }
      .feeline-menu-heading {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-weight: 400;
        font-size: clamp(2rem, 3.4vw, 3.4rem);
        line-height: 1.15;
        color: #2A2A2A;
        margin: 0 0 1.5rem 0;
      }
      .feeline-menu-heading em {
        font-style: italic;
        color: #BFA46A;
      }
      .feeline-menu-intro {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-size: 1.28rem;
        line-height: 1.7;
        color: #2A2A2A;
        opacity: 0.8;
        max-width: 48rem;
        margin: 0 auto 2rem auto;
      }
      .feeline-filet {
        width: 50px;
        height: 1px;
        background-color: #D4AF37;
        margin: 0 auto;
      }
      /* ----- Les 4 cartes papier ----- */
      .feeline-menu-cards {
        max-width: 1280px;
        margin: 0 auto 4rem auto;
        padding: 0 6vw;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
      }
      .feeline-card {
        position: relative;
        padding: 3rem 1.6rem 2.2rem;
        background-color: #FCFAF3;
        background-image:
          radial-gradient(ellipse at 30% 20%, rgba(212, 175, 55, 0.06) 0%, transparent 60%),
          radial-gradient(ellipse at 70% 80%, rgba(212, 175, 55, 0.05) 0%, transparent 55%),
          repeating-linear-gradient(0deg, rgba(212, 175, 55, 0.015) 0px, rgba(212, 175, 55, 0.015) 1px, transparent 1px, transparent 3px);
        border: 1px solid rgba(212, 175, 55, 0.22);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.8) inset,
          0 14px 30px rgba(42, 42, 42, 0.07),
          0 3px 8px rgba(42, 42, 42, 0.04);
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s;
      }
      .feeline-card::before {
        content: "";
        position: absolute;
        top: 1.4rem;
        left: 50%;
        transform: translateX(-50%);
        width: 32px;
        height: 1px;
        background-color: #D4AF37;
      }
      .feeline-card:hover {
        transform: translateY(-6px);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.8) inset,
          0 24px 52px rgba(212, 175, 55, 0.20),
          0 6px 16px rgba(42, 42, 42, 0.08);
        z-index: 3;
      }
      .feeline-card-num {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 500;
        font-size: 1.7rem;
        color: #BFA46A;
        margin-top: 1.2rem;
        line-height: 1;
      }
      .feeline-card-label {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.62rem;
        font-weight: 500;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #2A2A2A;
        opacity: 0.55;
        margin: 0.5rem 0 1rem 0;
      }
      .feeline-card-dish {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 400;
        font-size: 1.4rem;
        line-height: 1.25;
        color: #2A2A2A;
        margin: 0;
      }
      .feeline-card-detail {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        color: #2A2A2A;
        opacity: 0.6;
        margin: 0.5rem 0 0 0;
        font-style: italic;
      }
      .feeline-menu-pairing {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #BFA46A;
        margin: 0;
      }
      @media (max-width: 991px) {
        .feeline-menu-cards {
          grid-template-columns: repeat(2, 1fr);
          gap: 1.5rem;
        }
      }
      @media (max-width: 600px) {
        .feeline-menu-cards {
          grid-template-columns: 1fr;
          max-width: 380px;
        }
      }

      /* ================================================================
         SECTION CONFIDENCES + CARTE DE CORRESPONDANCE
         Diptyque éditorial inspiré du carton d'invitation gravé.
         Confidences numérotées en chiffres romains à gauche,
         carte papier vellum à droite avec sous lignes pointillées.
         ================================================================ */
      .feeline-faq-section {
        background-color: #FFFFFF;
        padding: 8rem 0 9rem 0;
        position: relative;
        overflow: hidden;
      }
      .feeline-faq-section::before,
      .feeline-faq-section::after {
        content: "";
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        width: clamp(80px, 9vw, 120px);
        height: 1px;
        background-color: #D4AF37;
        opacity: 0.55;
      }
      .feeline-faq-section::before { top: 4.5rem; }
      .feeline-faq-section::after  { bottom: 4.5rem; }
      .feeline-faq-container {
        max-width: 1240px;
        margin: 0 auto;
        padding: 0 6vw;
        position: relative;
      }
      .feeline-faq-header {
        text-align: center;
        margin-bottom: 5.5rem;
        max-width: 720px;
        margin-left: auto;
        margin-right: auto;
      }
      .feeline-faq-eyebrow {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.66rem;
        font-weight: 500;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: #BFA46A;
        margin: 0 0 1.4rem 0;
      }
      .feeline-faq-heading {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 400;
        font-size: clamp(2.6rem, 5vw, 4.4rem);
        line-height: 1;
        color: #2A2A2A;
        margin: 0 0 1.4rem 0;
        letter-spacing: -0.005em;
      }
      .feeline-faq-subtitle {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-size: clamp(1.05rem, 1.3vw, 1.2rem);
        color: #2A2A2A;
        opacity: 0.65;
        line-height: 1.55;
        margin: 0;
      }
      /* ----- Confidences éditoriales ----- */
      .feeline-faq-list {
        display: flex;
        flex-direction: column;
        max-width: 820px;
        margin: 0 auto;
      }
      .feeline-faq-item {
        border-top: 1px solid rgba(191, 164, 106, 0.4);
        padding: 1.9rem 0;
      }
      .feeline-faq-item:last-child {
        border-bottom: 1px solid rgba(191, 164, 106, 0.4);
      }
      .feeline-faq-item > summary {
        list-style: none;
        cursor: pointer;
        display: grid;
        grid-template-columns: 3.4rem 1fr auto;
        align-items: baseline;
        gap: 1.6rem;
      }
      .feeline-faq-item > summary::-webkit-details-marker { display: none; }
      .feeline-faq-numeral {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 500;
        font-size: 1.75rem;
        color: #BFA46A;
        line-height: 1;
        transition: color 0.3s ease;
        letter-spacing: 0.02em;
      }
      .feeline-faq-question {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(1.2rem, 1.55vw, 1.55rem);
        font-weight: 400;
        font-style: italic;
        color: #2A2A2A;
        line-height: 1.35;
        transition: color 0.3s ease;
      }
      .feeline-faq-toggle {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-size: 1rem;
        color: #BFA46A;
        white-space: nowrap;
        align-self: center;
        opacity: 0.7;
