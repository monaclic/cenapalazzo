      .feeline-faq-answer a:hover { color: #D4AF37; }

      /* ================================================================
         SECTION LE LIEU · grille éditoriale 2 colonnes, sans dépendance
         aux animations Velour sticky-about (qui ne supportent qu'une
         instance par page). Photos à gauche, 3 blocs info à droite.
         ================================================================ */
      .feeline-lieu-section {
        background-color: #FFFFFF;
        padding: 8rem 0 9rem 0;
        position: relative;
        overflow: hidden;
      }
      .feeline-lieu-section::before,
      .feeline-lieu-section::after {
        content: "";
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        width: clamp(80px, 9vw, 120px);
        height: 1px;
        background-color: #D4AF37;
        opacity: 0.55;
      }
      .feeline-lieu-section::before { top: 4.5rem; }
      .feeline-lieu-section::after  { bottom: 4.5rem; }
      .feeline-lieu-container {
        max-width: 1240px;
        margin: 0 auto;
        padding: 0 6vw;
      }
      .feeline-lieu-header {
        text-align: center;
        margin: 0 auto 5rem auto;
        max-width: 720px;
      }
      .feeline-lieu-layout {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 5rem;
        align-items: start;
      }
      .feeline-lieu-images {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .feeline-lieu-image {
        width: 100%;
        aspect-ratio: 4 / 5;
        object-fit: cover;
        display: block;
      }
      .feeline-lieu-blocks {
        display: flex;
        flex-direction: column;
        gap: 3.2rem;
      }
      .feeline-lieu-block {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }
      .feeline-lieu-block-eyebrow {
        font-family: "Montserrat", system-ui, sans-serif;
        font-size: 0.62rem;
        font-weight: 500;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #BFA46A;
        margin: 0;
