      /* ================================================================
         SECTION A PROPOS · adaptation proche de la section Velour fournie.
         On garde la structure sticky-about, avec des overrides de stabilité
         pour éviter les positions invisibles avant animation Webflow.
         ================================================================ */
      .feeline-about-section {
        background-color: #FFFFFF;
        position: relative;
        overflow: hidden;
      }
      .feeline-about-section .sticky-title-layout {
        color: #2A2A2A;
