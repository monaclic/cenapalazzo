        var targets = (split && split.words && split.words.length) ? split.words : [h2];
        gsap.set(targets, { opacity: 0, y: 30 });
        gsap.to(targets, {
          opacity: 1,
          y: 0,
          duration: 1.2,
          ease: 'power2.out',
          stagger: 0.08,
          scrollTrigger: {
