      .feeline-faq-item[open] .feeline-faq-toggle::before { content: "Refermer"; }
      .feeline-faq-item:not([open]) .feeline-faq-toggle::before { content: "Lire la réponse"; }
      .feeline-faq-item > summary:hover .feeline-faq-numeral,
