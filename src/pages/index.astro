---
import Base from '../layouts/Base.astro';
---

<Base>
  <main class="min-h-screen flex flex-col items-center justify-center px-8 py-24 text-center">
    <p class="font-sans text-[0.7rem] tracking-ceremonial uppercase text-orMetallise mb-10">
      Sous la présidence de S.A.S. le Prince Albert II de Monaco
    </p>

    <h1 class="font-serif font-light text-5xl sm:text-6xl md:text-7xl tracking-ultratight leading-none mb-6">
      Cena a Palazzo
    </h1>

    <p class="font-sans text-xs tracking-widest uppercase text-encre/70 mb-12">
      Dîner de bienfaisance
    </p>

    <div class="w-20 h-px bg-orDore mb-12"></div>

    <p class="font-serif italic text-2xl md:text-3xl mb-3">
      22 juin 2026
    </p>
    <p class="font-sans text-[0.75rem] tracking-wider uppercase text-encre/70 mb-12">
      Casino di Sanremo · Salle Privée
    </p>

    <div class="w-20 h-px bg-orDore mb-12"></div>

    <p class="font-serif italic text-base md:text-lg text-encre/80 max-w-prose mb-2">
      Au profit de la Fondation Prince Albert II de Monaco
    </p>

    <p class="font-sans text-[0.65rem] tracking-ceremonial uppercase text-orMetallise mt-16">
      Site en préparation
    </p>
  </main>
</Base>
