          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 1rem;
        }
        .feeline-about-section .sticky-side-image {
          position: relative;
          top: auto !important;
          right: auto !important;
          bottom: auto !important;
          left: auto !important;
