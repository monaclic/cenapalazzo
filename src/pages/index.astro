      .feeline-lieu-block-title {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-weight: 400;
        font-size: clamp(1.4rem, 2vw, 1.85rem);
        line-height: 1.25;
        color: #2A2A2A;
        margin: 0;
      }
      .feeline-lieu-block-divider {
        width: 32px;
        height: 1px;
        background-color: #D4AF37;
        margin: 0.4rem 0 0.3rem 0;
      }
      .feeline-lieu-block-text {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: 1.12rem;
        line-height: 1.75;
        color: #2A2A2A;
        opacity: 0.78;
        margin: 0;
