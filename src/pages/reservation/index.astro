---
const translations = {
  fr: {
    title: 'Demande de réservation · Cena a Palazzo',
    description: 'Formulaire de demande de réservation pour Cena a Palazzo, dîner de gala au Casino di Sanremo le 22 juin 2026.',
    homeHref: '/',
    eyebrow: 'Demande de réservation',
    heading: 'Réserver sa place',
    intro: "Merci de compléter ce formulaire. L'équipe Cena a Palazzo reviendra vers vous par e-mail pour confirmer votre demande.",
    back: 'Retour au site',
    languageLabel: 'Langues',
    fields: {
      firstName: 'Prénom',
      lastName: 'Nom',
      email: 'Adresse e-mail',
      phone: 'Numéro de téléphone avec indicatif',
      guests: 'Nombre de personnes à réserver',
      allergies: 'Allergies ou intolérances alimentaires',
      vehicle: "Numéro d'immatriculation du véhicule",
      vehicleHint: 'À renseigner uniquement si vous venez en voiture.',
      phonePlaceholder: 'Exemple: +33 6 12 34 56 78',
      allergiesPlaceholder: "Indiquez les allergies, intolérances alimentaires ou toute information que l'organisation devrait connaître.",
      vehiclePlaceholder: 'Exemple: AB 123 CD',
    },
    submit: 'Envoyer la demande',
    mailSubject: 'Demande de réservation Cena a Palazzo',
    mailIntro: 'Bonjour, voici une nouvelle demande de réservation pour Cena a Palazzo.',
    pending: 'Préparation de votre demande...',
    successTitle: 'Merci pour votre demande',
    successMessage: "Votre demande est prête. Votre messagerie va s'ouvrir avec un e-mail prérempli à envoyer à info@e20sanremo.it. L'équipe Cena a Palazzo reviendra vers vous par e-mail.",
    errorMessage: 'Merci de vérifier les champs obligatoires avant envoi.',
    spamMessage: 'Votre demande n’a pas pu être envoyée.',
    honeypot: 'Site internet',
    required: 'Champ obligatoire',
  },
  en: {
    title: 'Booking request · Cena a Palazzo',
    description: 'Booking request form for Cena a Palazzo, gala dinner at the Casino di Sanremo on 22 June 2026.',
    homeHref: '/en/',
    eyebrow: 'Booking request',
    heading: 'Book your seat',
    intro: 'Please complete this form. The Cena a Palazzo team will get back to you by email to confirm your request.',
    back: 'Back to site',
    languageLabel: 'Languages',
    fields: {
      firstName: 'First name',
      lastName: 'Last name',
      email: 'Email address',
      phone: 'Phone number with country code',
      guests: 'Number of guests to reserve',
      allergies: 'Food allergies or intolerances',
      vehicle: 'Vehicle registration number',
      vehicleHint: 'Only fill this in if you are coming by car.',
      phonePlaceholder: 'Example: +44 7 1234 5678',
      allergiesPlaceholder: 'List food allergies, intolerances or any information the organization should know.',
      vehiclePlaceholder: 'Example: AB 123 CD',
    },
    submit: 'Send request',
    mailSubject: 'Cena a Palazzo booking request',
    mailIntro: 'Hello, here is a new booking request for Cena a Palazzo.',
    pending: 'Preparing your request...',
    successTitle: 'Thank you for your request',
    successMessage: 'Your request is ready. Your email app will open with a prefilled message to send to info@e20sanremo.it. The Cena a Palazzo team will get back to you by email.',
    errorMessage: 'Please check the required fields before sending.',
    spamMessage: 'Your request could not be sent.',
    honeypot: 'Website',
    required: 'Required field',
  },
  it: {
    title: 'Richiesta di prenotazione · Cena a Palazzo',
    description: 'Modulo di richiesta di prenotazione per Cena a Palazzo, cena di gala al Casino di Sanremo il 22 giugno 2026.',
    homeHref: '/it/',
    eyebrow: 'Richiesta di prenotazione',
    heading: 'Prenotare il posto',
    intro: 'Compilate il modulo. Il team Cena a Palazzo vi ricontatterà via e-mail per confermare la richiesta.',
    back: 'Torna al sito',
    languageLabel: 'Lingue',
    fields: {
      firstName: 'Nome',
      lastName: 'Cognome',
      email: 'Indirizzo e-mail',
      phone: 'Numero di telefono con prefisso internazionale',
      guests: 'Numero di persone da prenotare',
      allergies: 'Allergie o intolleranze alimentari',
      vehicle: 'Numero di targa del veicolo',
      vehicleHint: 'Da compilare solo se arrivate in auto.',
      phonePlaceholder: 'Esempio: +39 333 123 4567',
      allergiesPlaceholder: "Indicate allergie, intolleranze alimentari o qualsiasi informazione utile per l'organizzazione.",
      vehiclePlaceholder: 'Esempio: AB 123 CD',
    },
    submit: 'Inviare la richiesta',
    mailSubject: 'Richiesta di prenotazione Cena a Palazzo',
    mailIntro: 'Buongiorno, ecco una nuova richiesta di prenotazione per Cena a Palazzo.',
    pending: 'Preparazione della richiesta...',
    successTitle: 'Grazie per la richiesta',
    successMessage: "La richiesta è pronta. La vostra app e-mail si aprirà con un messaggio precompilato da inviare a info@e20sanremo.it. Il team Cena a Palazzo vi ricontatterà via e-mail.",
    errorMessage: "Controllate i campi obbligatori prima dell'invio.",
    spamMessage: 'La richiesta non è stata inviata.',
    honeypot: 'Sito internet',
    required: 'Campo obbligatorio',
  },
} as const;

type Locale = keyof typeof translations;
const localeFromPath = Astro.url.pathname.split('/').filter(Boolean)[0];
const locale = (localeFromPath in translations ? localeFromPath : 'fr') as Locale;
const t = translations[locale];
const languageOptions: Array<{ lang: Locale; label: string; href: string }> = [
  { lang: 'fr', label: 'FR', href: '/reservation/' },
  { lang: 'en', label: 'EN', href: '/en/reservation/' },
  { lang: 'it', label: 'IT', href: '/it/reservation/' },
];
const phonePattern = String.raw`\+[0-9][0-9\s().-]{6,}`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <title>{t.title}</title>
    <meta name="description" content={t.description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {languageOptions.map((option) => (
      <link rel="alternate" hreflang={option.lang} href={`https://cenapalazzo.com${option.href}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://cenapalazzo.com/reservation/" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin="anonymous" />
    <script src="https://ajax.googleapis.com/ajax/libs/webfont/1.6.26/webfont.js" type="text/javascript" is:inline></script>
    <script type="text/javascript" is:inline>WebFont.load({ google: { families: ["Cormorant Garamond:300,400,500,600,700","Cormorant Garamond:ital,300,400,500,600,700","Montserrat:300,400,500,600,700"] } });</script>
    <style>
      :root {
        --ink: #2A2A2A;
        --gold: #BFA46A;
        --gold-strong: #D4AF37;
        --paper: #FFFFFF;
        --champagne: #EFE6D3;
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        min-height: 100%;
        background: var(--paper);
        color: var(--ink);
      }
      body {
        font-family: "Montserrat", system-ui, sans-serif;
      }
      a {
        color: inherit;
      }
      .reservation-page {
        min-height: 100svh;
        padding: clamp(1rem, 3vw, 1.75rem);
        background:
          linear-gradient(180deg, #FFFFFF 0%, #FFFFFF 58%, #EFE6D3 100%);
      }
      .reservation-frame {
        min-height: calc(100svh - clamp(2rem, 6vw, 3.5rem));
        border: 1px solid rgba(191, 164, 106, 0.34);
        padding: clamp(1.25rem, 5vw, 4rem);
      }
      .reservation-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: clamp(3rem, 7vw, 6rem);
      }
      .brand-link {
        text-decoration: none;
      }
      .brand-wordmark {
        display: block;
        font-family: "Cormorant Garamond", Georgia, serif;
        font-style: italic;
        font-size: clamp(1.25rem, 3vw, 1.75rem);
        line-height: 1;
      }
      .nav-tools {
        display: flex;
        align-items: center;
        gap: clamp(0.9rem, 2vw, 1.5rem);
      }
      .back-link,
      .language-link {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        text-decoration: none;
      }
      .back-link,
      .language-link.is-active {
        color: #8A7530;
      }
      .language-switcher {
        display: inline-flex;
        gap: 0.5rem;
      }
      .language-link {
        color: rgba(42, 42, 42, 0.52);
      }
      .reservation-layout {
        display: grid;
        grid-template-columns: minmax(0, 0.86fr) minmax(0, 1.14fr);
        gap: clamp(3rem, 7vw, 7rem);
        align-items: start;
        max-width: 1240px;
        margin: 0 auto;
      }
      .reservation-eyebrow {
        margin: 0 0 1.15rem;
        color: #8A7530;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }
      .reservation-title {
        margin: 0;
        max-width: 42rem;
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(4rem, 9vw, 8rem);
        font-style: italic;
        font-weight: 500;
        line-height: 0.92;
      }
      .reservation-intro {
        margin: 2rem 0 0;
        max-width: 34rem;
        color: rgba(42, 42, 42, 0.72);
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(1.12rem, 1.5vw, 1.35rem);
        line-height: 1.7;
      }
      .reservation-form {
        display: grid;
        gap: 1rem;
        padding: clamp(1.1rem, 3vw, 2rem);
        background: rgba(255, 255, 255, 0.76);
        border: 1px solid rgba(191, 164, 106, 0.32);
        box-shadow: 0 1.6rem 4rem rgba(42, 42, 42, 0.08);
      }
      .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
      }
      .field {
        display: grid;
        gap: 0.5rem;
      }
      .field.is-wide {
        grid-column: 1 / -1;
      }
      .field.is-trap {
        position: absolute;
        left: -10000px;
        width: 1px;
        height: 1px;
        opacity: 0;
        overflow: hidden;
      }
      label {
        color: #5f4f20;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      input,
      textarea {
        width: 100%;
        border: 1px solid rgba(191, 164, 106, 0.38);
        border-radius: 0;
        background: #FFFFFF;
        color: var(--ink);
        font: inherit;
        font-size: 1rem;
        line-height: 1.4;
        padding: 0.95rem 1rem;
        outline: none;
        transition: border-color 0.24s ease, box-shadow 0.24s ease;
      }
      input:focus,
      textarea:focus {
        border-color: var(--gold-strong);
        box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.12);
      }
      textarea {
        min-height: 8rem;
        resize: vertical;
      }
      .hint {
        margin: -0.2rem 0 0;
        color: rgba(42, 42, 42, 0.58);
        font-size: 0.82rem;
        line-height: 1.5;
      }
      .submit-button {
        justify-self: start;
        margin-top: 0.75rem;
        border: 1px solid var(--gold);
        background: #FFFFFF;
        color: var(--ink);
        cursor: pointer;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        padding: 1rem 1.35rem;
        text-transform: uppercase;
        transition: background-color 0.24s ease, border-color 0.24s ease;
      }
      .submit-button:hover {
        background: rgba(212, 175, 55, 0.08);
        border-color: var(--gold-strong);
      }
      .submit-button:disabled {
        cursor: wait;
        opacity: 0.62;
      }
      .form-status {
        min-height: 1.4rem;
        margin: 0.4rem 0 0;
        color: #6f5d25;
        font-size: 0.9rem;
        line-height: 1.5;
      }
      .form-status.is-error {
        color: #8b1e1e;
      }
      .reservation-success {
        display: grid;
        gap: 0.8rem;
        padding: clamp(1.35rem, 3vw, 2rem);
        border: 1px solid rgba(191, 164, 106, 0.34);
        background: rgba(255, 255, 255, 0.82);
        box-shadow: 0 1.6rem 4rem rgba(42, 42, 42, 0.08);
      }
      .reservation-success.is-hidden,
      .reservation-form.is-hidden {
        display: none;
      }
      .reservation-success-title {
        margin: 0;
        color: #5f4f20;
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(2rem, 4vw, 3rem);
        font-style: italic;
        font-weight: 500;
        line-height: 1;
      }
      .reservation-success-text {
        margin: 0;
        color: rgba(42, 42, 42, 0.72);
        font-size: 0.98rem;
        line-height: 1.7;
      }
      @media (max-width: 900px) {
        .reservation-layout,
        .form-grid {
          grid-template-columns: 1fr;
        }
        .reservation-nav {
          align-items: flex-start;
          flex-direction: column;
        }
        .nav-tools {
          width: 100%;
          justify-content: space-between;
        }
      }
      @media (max-width: 560px) {
        .reservation-page {
          padding: 0.75rem;
        }
        .reservation-frame {
          padding: 1.25rem;
        }
        .reservation-title {
          font-size: clamp(3.4rem, 17vw, 4.8rem);
        }
        .submit-button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main class="reservation-page">
      <div class="reservation-frame">
        <nav class="reservation-nav" aria-label="Reservation navigation">
          <a href={t.homeHref} class="brand-link">
            <span class="brand-wordmark">Cena a Palazzo</span>
          </a>
          <div class="nav-tools">
            <a href={t.homeHref} class="back-link">{t.back}</a>
            <div class="language-switcher" aria-label={t.languageLabel}>
              {languageOptions.map((option) => (
                <a href={option.href} class:list={['language-link', { 'is-active': option.lang === locale }]} aria-current={option.lang === locale ? 'page' : undefined}>{option.label}</a>
              ))}
            </div>
          </div>
        </nav>

        <div class="reservation-layout">
          <section>
            <p class="reservation-eyebrow">{t.eyebrow}</p>
            <h1 class="reservation-title">{t.heading}</h1>
            <p class="reservation-intro">{t.intro}</p>

          </section>

          <form class="reservation-form" id="reservation-form" action="mailto:info@e20sanremo.it" method="post" enctype="text/plain" data-locale={locale} data-subject={t.mailSubject} data-intro={t.mailIntro} data-pending={t.pending} data-error={t.errorMessage} data-spam={t.spamMessage}>
            <div class="form-grid">
              <div class="field is-trap" aria-hidden="true">
                <label for="website">{t.honeypot}</label>
                <input id="website" name="website" tabindex="-1" autocomplete="off" />
              </div>
              <div class="field">
                <label for="firstName">{t.fields.firstName}</label>
                <input id="firstName" name={t.fields.firstName} autocomplete="given-name" minlength="2" maxlength="80" required aria-required="true" title={t.required} />
              </div>
              <div class="field">
                <label for="lastName">{t.fields.lastName}</label>
                <input id="lastName" name={t.fields.lastName} autocomplete="family-name" minlength="2" maxlength="80" required aria-required="true" title={t.required} />
              </div>
              <div class="field">
                <label for="email">{t.fields.email}</label>
                <input id="email" name={t.fields.email} type="email" autocomplete="email" maxlength="140" required aria-required="true" title={t.required} />
              </div>
              <div class="field">
                <label for="phone">{t.fields.phone}</label>
                <input id="phone" name={t.fields.phone} type="tel" autocomplete="tel" placeholder={t.fields.phonePlaceholder} pattern={phonePattern} maxlength="32" required aria-required="true" title={t.required} />
              </div>
              <div class="field is-wide">
                <label for="guests">{t.fields.guests}</label>
                <input id="guests" name={t.fields.guests} type="number" min="1" max="20" step="1" inputmode="numeric" required aria-required="true" title={t.required} />
              </div>
              <div class="field is-wide">
                <label for="allergies">{t.fields.allergies}</label>
                <textarea id="allergies" name={t.fields.allergies} placeholder={t.fields.allergiesPlaceholder} minlength="2" maxlength="600" required aria-required="true" title={t.required}></textarea>
              </div>
              <div class="field is-wide">
                <label for="vehicle">{t.fields.vehicle}</label>
                <input id="vehicle" name={t.fields.vehicle} placeholder={t.fields.vehiclePlaceholder} maxlength="40" />
                <p class="hint">{t.fields.vehicleHint}</p>
              </div>
            </div>
            <button type="submit" class="submit-button">{t.submit}</button>
            <p class="form-status" id="form-status" aria-live="polite"></p>
          </form>
          <div class="reservation-success is-hidden" id="reservation-success" role="status" aria-live="polite">
            <h2 class="reservation-success-title">{t.successTitle}</h2>
            <p class="reservation-success-text">{t.successMessage}</p>
          </div>
        </div>
      </div>
    </main>

    <script is:inline>
      (function () {
        var form = document.getElementById('reservation-form');
        var status = document.getElementById('form-status');
        var success = document.getElementById('reservation-success');
        var startedAt = Date.now();
        if (!form) return;

        form.addEventListener('submit', function (event) {
          event.preventDefault();
          var submitButton = form.querySelector('button[type="submit"]');
          var trap = form.querySelector('input[name="website"]');
          if (status) {
            status.textContent = '';
            status.classList.remove('is-error');
          }
          if (trap && trap.value.trim() !== '') {
            if (status) {
              status.textContent = form.dataset.spam || '';
              status.classList.add('is-error');
            }
            return;
          }
          if (Date.now() - startedAt < 900) {
            if (status) {
              status.textContent = form.dataset.error || '';
              status.classList.add('is-error');
            }
            return;
          }
          if (!form.checkValidity()) {
            if (status) {
              status.textContent = form.dataset.error || '';
              status.classList.add('is-error');
            }
            form.reportValidity();
            return;
          }

          if (submitButton) submitButton.disabled = true;
          if (status) status.textContent = form.dataset.pending || '';
          var data = new FormData(form);
          var lines = [form.dataset.intro || '', '', 'Langue / Language / Lingua: ' + (form.dataset.locale || 'fr')];
          data.forEach(function (value, key) {
            var cleanValue = String(value).trim();
            if (key !== 'website' && cleanValue !== '') {
              lines.push(key + ': ' + cleanValue);
            }
          });

          var subject = encodeURIComponent(form.dataset.subject || 'Cena a Palazzo');
          var body = encodeURIComponent(lines.join('\n'));
          window.location.href = 'mailto:info@e20sanremo.it?subject=' + subject + '&body=' + body;
          form.classList.add('is-hidden');
          if (success) success.classList.remove('is-hidden');
        });
      })();
    </script>
  </body>
</html>
