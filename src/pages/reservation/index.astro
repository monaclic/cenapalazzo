      },
      {
        title: 'Billet électronique',
        text: "Après réception de la confirmation de paiement, l'organisation enverra votre confirmation définitive, votre billet électronique personnalisé et les informations logistiques utiles.",
      },
    ],
    required: 'Champ obligatoire',
  },
  en: {
    title: 'Booking request · Cena a Palazzo',
    description: 'Booking request form for Cena a Palazzo, gala dinner at the Casino di Sanremo on 22 June 2026.',
    homeHref: '/en/',
    eyebrow: 'Booking request',
    heading: 'Book your seat',
    intro: 'Please complete this form. The organization will check availability before sending you the official payment link from the Prince Albert II of Monaco Foundation.',
    back: 'Back to site',
    languageLabel: 'Languages',
    fields: {
      firstName: 'First name',
      lastName: 'Last name',
      email: 'Email address',
      phone: 'Phone number',
      guests: 'Number of guests to reserve',
      allergies: 'Food allergies or intolerances',
      vehicle: 'Vehicle registration number',
      vehicleHint: 'Only fill this in if you are coming by car.',
      allergiesPlaceholder: 'List allergies, intolerances or write none.',
      vehiclePlaceholder: 'Example: AB 123 CD',
    },
    submit: 'Send request',
    mailSubject: 'Cena a Palazzo booking request',
    mailIntro: 'Hello, here is a new booking request for Cena a Palazzo.',
    status: 'Your email app will open with the request filled in. Send the email to info@e20sanremo.it to complete the request.',
    stepsTitle: 'After your request',
    steps: [
      {
        title: 'Availability check',
