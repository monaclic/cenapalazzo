---
import '../styles/nav.css';

interface Props {
  reserveHref?: string;
  currentLang?: 'fr' | 'it' | 'en';
}

const {
  reserveHref = 'https://www.fpa2.org/fr/evenements/cena-a-palazzo-028',
  currentLang = 'fr',
} = Astro.props;

const links = [
  { href: '#evenement', label: "L'Événement" },
  { href: '#diner', label: 'Le Dîner' },
  { href: '#menu', label: 'Le Menu' },
  { href: '#lieu', label: 'Le Lieu' },
  { href: '#contact', label: 'Contact' },
];
---

<header data-nav-header-trigger="true" class="nav-header">

  <!-- Bloc gauche · wordmark + ligne dorée + slogan -->
  <div class="nav-brand">
    <a href="/" aria-current="page" class="brand-logo-link">
      <span class="logo-wordmark" aria-label="Cena a Palazzo">
        <span class="logo-wordmark-line-1">Cena</span>
        <span class="logo-wordmark-line-2">a Palazzo</span>
      </span>
      <span class="slogan-line" aria-hidden="true"></span>
      <span class="slogan-text">
        Dîner de bienfaisance · 22 juin 2026
      </span>
    </a>
  </div>

  <!-- Bloc droit · liens + langues + CTA -->
  <nav class="nav-links" aria-label="Navigation principale">
    {links.map(({ href, label }) => (
      <a href={href} class="nav-link">{label}</a>
    ))}

    <span class="nav-divider" aria-hidden="true"></span>

    <span class="nav-lang" aria-label="Sélecteur de langue">
      <span class={currentLang === 'fr' ? 'is-active' : ''}>
        {currentLang === 'fr' ? <span>FR</span> : <a href="/">FR</a>}
      </span>
      <span class="nav-lang-sep">·</span>
      <span class={currentLang === 'it' ? 'is-active' : ''}>
        {currentLang === 'it' ? <span>IT</span> : <a href="/it/">IT</a>}
      </span>
      <span class="nav-lang-sep">·</span>
      <span class={currentLang === 'en' ? 'is-active' : ''}>
        {currentLang === 'en' ? <span>EN</span> : <a href="/en/">EN</a>}
      </span>
    </span>

    <a
      href={reserveHref}
      target="_blank"
      rel="noopener noreferrer"
      class="nav-reserve"
    >
      Réserver
    </a>
  </nav>

</header>
