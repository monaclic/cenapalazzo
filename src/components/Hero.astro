---
import '../styles/hero.css';

interface Props {
  reserveHref?: string;
}

const { reserveHref = '/reservation/' } = Astro.props;
---

<section class="hero-section">
  <div class="home-hero-size">

    <!-- Couche texte, sticky en haut -->
    <div class="home-hero-layout">
      <div class="home-hero-content">

        <span class="hero-eyebrow">
          Sous la présidence de S.A.S. le Prince Albert II de Monaco
        </span>

        <div class="home-hero-title">
          <h1 class="heading is-home-hero-title">Cena a Palazzo</h1>
          <div class="dot-position-hero" aria-hidden="true">
            <div class="dot">
              <div class="dot-animation"></div>
            </div>
          </div>
        </div>

        <span class="hero-subtitle">
          Dîner de bienfaisance · 22 juin 2026 · Casino di Sanremo
        </span>

        <a href="#start" class="regular-link" aria-label="Découvrir le lieu">
          <span class="regular-link-text">Découvrir</span>
          <svg
            class="regular-link-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 5v14M5 12l7 7 7-7" />
          </svg>
          <span class="regular-link-line" aria-hidden="true"></span>
        </a>

      </div>

      <!-- Mesh gradients d'ambiance -->
      <div class="mesh-bgs-wrapper" aria-hidden="true">
        <div class="mesh-bg-1-center"></div>
        <div class="mesh-bg-2-center"></div>
        <div class="mesh-bg-3-left"></div>
        <div class="mesh-bg-4-right"></div>
      </div>
    </div>

    <!-- Galerie sticky d'images -->
    <div id="start" class="home-hero-images">
      <div class="home-hero-sticky">

        <div class="home-hero-image is-1st">
          <img
            src="/assets/photos/casino-facade-jour.jpg"
            alt="Façade du Casino di Sanremo en journée, palmiers et ciel bleu"
            class="hero-cover-image-1"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>

        <div class="home-hero-image is-2nd">
          <img
            src="/assets/photos/sala-casino-02.jpg"
            alt="Salle Privée du Casino di Sanremo, parquet et plafond Belle Époque"
            class="hero-cover-image-2"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="home-hero-image is-3rd">
          <img
            src="/assets/photos/casino-facade-nuit.jpg"
            alt="Façade du Casino di Sanremo illuminée la nuit"
            class="hero-cover-image-3"
            loading="eager"
            decoding="async"
          />
        </div>

      </div>
    </div>

  </div>
</section>
